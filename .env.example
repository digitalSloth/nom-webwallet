# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# WalletConnect Cloud / Reown project ID — https://dashboard.reown.com
# Required for the Phase 2 WalletConnect integration. When unset, the wallet
# disables WalletConnect features (with a clear developer-facing message) rather
# than failing the build.
VITE_WALLETCONNECT_PROJECT_ID=
