{
  "name": "nom-ui",
  "version": "1.0.0",
  "type": "module",
  "description": "Shared shadcn-vue component library for NoM apps (Vue 3 + Tailwind CSS 4)",
  "keywords": [
    "vue",
    "vue3",
    "shadcn-vue",
    "tailwindcss",
    "components",
    "ui"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./style.css": "./src/style.css",
    "./components": "./src/components/index.ts",
    "./composables": "./src/composables/index.ts",
    "./lib/utils": "./src/lib/utils.ts"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.563.0",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.4.0",
    "vue-sonner": "^2.0.9"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}
